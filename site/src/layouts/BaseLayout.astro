---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../config';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const currentPath = Astro.url.pathname;
const pageTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32x32.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
  </head>
  <body>
    <SiteHeader currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
